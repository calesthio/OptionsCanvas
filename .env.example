# Alpaca API Credentials
# Get your keys from: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_PAPER=true
ALPACA_DATA_FEED=sip

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your_secret_key_here

# Database
DATABASE_PATH=assisted_trading/state/trading.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=assisted_trading/logs

# Trading Configuration
DEFAULT_POSITION_SIZE=1000
MAX_POSITION_SIZE=10000
AUTO_SELL_ON_SL=true
AUTO_SELL_ON_TP=true

# Market Hours (ET timezone)
MARKET_TIMEZONE=America/New_York
PREMARKET_START=04:00
REGULAR_START=09:30
REGULAR_END=16:00
AFTERHOURS_END=20:00

# WebSocket
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=60

# Optional: Discord Webhook for Alerts
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
